# ---------------------------------------------------------------------------
# Hedera Cyclops — example environment configuration.
# Copy to `.env` for local development. NEVER commit real values.
# In production, set these only via the Railway dashboard / CLI.
# Any variable prefixed NEXT_PUBLIC_ ships to the browser — never put a
# secret behind a NEXT_PUBLIC_ name.
# ---------------------------------------------------------------------------

# Postgres connection string (Railway Postgres addon provides this).
DATABASE_URL="postgresql://user:password@localhost:5432/hedera_cyclops?schema=public"

# Hedera network: "mainnet" or "testnet".
HEDERA_NETWORK="testnet"

# Comma-separated list of HTS token IDs that gate the site.
# Leave EMPTY until a real collection is minted — the site runs in
# "not yet minted" placeholder mode while empty.
HEDERA_TOKEN_IDS=""

# Hedera Mirror Node REST base URL (no trailing slash).
# testnet: https://testnet.mirrornode.hedera.com
# mainnet: https://mainnet-public.mirrornode.hedera.com
MIRROR_NODE_BASE_URL="https://testnet.mirrornode.hedera.com"

# IPFS gateway used to resolve ipfs:// media/metadata URIs (no trailing slash).
IPFS_GATEWAY_URL="https://ipfs.io"

# Secret used to sign session JWTs. Generate a long random string.
# NEVER hardcode, log, or expose this.
AUTH_JWT_SECRET="change-me-to-a-long-random-secret"

# Name of the httpOnly session cookie.
AUTH_COOKIE_NAME="hc_session"

# S3-compatible object storage (works with Cloudflare R2, AWS S3, MinIO, ...).
OBJECT_STORAGE_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_BUCKET="hedera-cyclops-uploads"
OBJECT_STORAGE_ACCESS_KEY_ID=""
OBJECT_STORAGE_SECRET_ACCESS_KEY=""
# Optional public base URL that serves objects in the bucket (CDN / R2 public URL).
OBJECT_STORAGE_PUBLIC_URL=""

# Comma-separated wallet addresses (0.0.x) granted admin/moderation powers.
ADMIN_WALLET_ADDRESSES=""

# Total maximum supply across all phases (config-driven, never hardcoded).
TOTAL_SUPPLY="3333"

# Optional per-phase supply targets for the homepage progress indicator.
# Format: "name:target,name:target,..."
PHASES="Phase 1:1500,Phase 2:1500,Phase 3:333"

# Enable the bundled local mock NFT dataset when no real token id is set.
# Ignored (never used) whenever HEDERA_TOKEN_IDS is non-empty.
USE_MOCK_NFTS="true"

# Public app URL (used for absolute links / WalletConnect metadata).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WalletConnect v2 Cloud project id (public by design — safe for the browser).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
